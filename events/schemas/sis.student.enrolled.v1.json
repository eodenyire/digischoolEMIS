{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sis.student.enrolled.v1",
  "title": "sis.student.enrolled.v1",
  "type": "object",
  "required": ["event_id", "event_type", "occurred_at", "tenant_id", "school_id", "actor", "trace", "enrollment"],
  "properties": {
    "event_id": {"type": "string", "format": "uuid"},
    "event_type": {"const": "sis.student.enrolled.v1"},
    "occurred_at": {"type": "string", "format": "date-time"},
    "tenant_id": {"type": "string", "format": "uuid"},
    "school_id": {"type": "string", "format": "uuid"},
    "actor": {
      "type": "object",
      "required": ["user_id", "role"],
      "properties": {
        "user_id": {"type": "string", "format": "uuid"},
        "role": {"type": "string"}
      }
    },
    "trace": {
      "type": "object",
      "required": ["request_id", "correlation_id"],
      "properties": {
        "request_id": {"type": "string", "format": "uuid"},
        "correlation_id": {"type": "string", "format": "uuid"}
      }
    },
    "enrollment": {
      "type": "object",
      "required": ["id", "student_id", "academic_year_id", "enrolled_at", "status"],
      "properties": {
        "id": {"type": "string", "format": "uuid"},
        "student_id": {"type": "string", "format": "uuid"},
        "academic_year_id": {"type": "string", "format": "uuid"},
        "term_id": {"type": ["string", "null"], "format": "uuid"},
        "enrolled_at": {"type": "string", "format": "date"},
        "status": {"type": "string"}
      }
    }
  }
}